{
  "expo": {
    "name": "OficiosPlaya",
    "slug": "oficios-playa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oficiosplaya",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0891B2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oficiosplaya.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0891B2"
      },
      "package": "com.oficiosplaya.app",
      "versionCode": 1
    },
    "updates": {
      "url": "https://u.expo.dev/TU_PROJECT_ID",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "OficiosPlaya necesita acceso a tus fotos para adjuntarlas a tu solicitud."
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Permite a OficiosPlaya almacenar datos de sesión de forma segura."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0891B2",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "TU_EAS_PROJECT_ID"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
